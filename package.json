{
  "name": "yoga-flow",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "release": "standard-version",
    "push-release": "git push --follow-tags origin master",
    "release:full": "standard-version && git push --follow-tags origin master",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitlint": "^21.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ],
    "*.{json,md}": [
      "biome check --write"
    ]
  }
}
