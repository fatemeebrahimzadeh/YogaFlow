{
  "name": "yoga-flow",
  "version": "0.1.2",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs",
    "arch:graph": "depcruise src --config .dependency-cruiser.cjs --output-type dot --output-to dependency-graph.dot",
    "docker:build": "docker build --target runner -t yoga-flow:local .",
    "docker:run": "docker compose up --build",
    "format": "biome format --write",
    "release": "standard-version",
    "push-release": "git push --follow-tags origin master",
    "release:full": "standard-version && git push --follow-tags origin master",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitlint": "^21.0.2",
    "dependency-cruiser": "^17.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ],
    "*.json": [
      "biome check --write"
    ]
  }
}
